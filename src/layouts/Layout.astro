---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
// PWA virtual module: provides manifest <link> tag info in prod builds,
// undefined in dev. Wired by @vite-pwa/astro in astro.config.mjs.
// @ts-ignore — virtual module, no static type
import { pwaInfo } from "virtual:pwa-info";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "chonklm — tiny language models, running offline in your browser",
  description = "Tiny language models, running offline in your browser. On-device inference in 2 minutes.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f8f4ee" id="theme-color-meta" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    {pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    {/* Theme bootstrap — runs before paint, no flash. */}
    <script is:inline>
      (function () {
        try {
          var pref = localStorage.getItem("theme") || "system";
          var sys = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
          var theme = pref === "system" ? sys : pref;
          var html = document.documentElement;
          html.setAttribute("data-theme", theme);
          html.setAttribute("data-theme-pref", pref);
          var meta = document.getElementById("theme-color-meta");
          if (meta) meta.setAttribute("content", theme === "dark" ? "#1a1a1a" : "#f8f4ee");
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    {/* SW registration — file generated by @vite-pwa/astro into dist/registerSW.js. */}
    <script src="/registerSW.js" is:inline></script>
  </body>
</html>
