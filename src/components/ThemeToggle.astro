---
// Tri-state cycle: system → light → dark → system.
// Persists to localStorage.theme and updates data-theme[-pref] on <html>.
---

<button
  class="theme-toggle"
  type="button"
  aria-label="Toggle theme"
  data-theme-toggle
>
  {/* sun */}
  <svg class="ico ico-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
    <circle cx="12" cy="12" r="4" />
    <path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" stroke-linecap="round" />
  </svg>
  {/* moon */}
  <svg class="ico ico-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z" stroke-linejoin="round" />
  </svg>
  {/* system */}
  <svg class="ico ico-system" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
    <rect x="3" y="4" width="18" height="13" rx="1" />
    <path d="M8 21h8M12 17v4" stroke-linecap="round" />
  </svg>
</button>

<script is:inline>
  (function () {
    var btn = document.querySelector("[data-theme-toggle]");
    if (!btn) return;
    btn.addEventListener("click", function () {
      var html = document.documentElement;
      var cur = html.getAttribute("data-theme-pref") || "system";
      var next = cur === "system" ? "light" : cur === "light" ? "dark" : "system";
      var sys = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
      var theme = next === "system" ? sys : next;
      html.setAttribute("data-theme-pref", next);
      html.setAttribute("data-theme", theme);
      try { localStorage.setItem("theme", next); } catch (e) {}
      var meta = document.getElementById("theme-color-meta");
      if (meta) meta.setAttribute("content", theme === "dark" ? "#1a1a1a" : "#f8f4ee");
    });

    // React to OS-theme changes while in system mode.
    window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", function (e) {
      var html = document.documentElement;
      if (html.getAttribute("data-theme-pref") !== "system") return;
      var theme = e.matches ? "dark" : "light";
      html.setAttribute("data-theme", theme);
      var meta = document.getElementById("theme-color-meta");
      if (meta) meta.setAttribute("content", theme === "dark" ? "#1a1a1a" : "#f8f4ee");
    });
  })();
</script>
